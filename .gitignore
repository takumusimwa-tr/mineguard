# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# Data — raw files are large, don't commit them
data/raw/
data/simulated/

# Processed data — ignore large CSVs but track figures
data/processed/*.csv
data/processed/.gitkeep

# Model binaries — large, don't commit
models/**/*.pkl
models/**/*.joblib
models/**/*.h5
models/**/*.pt
models/**/*.pth

# But DO track model metadata
!models/**/metadata.json
!models/**/feature_columns.json

# MLflow runs
mlruns/
mlflow/

# Logs — track folder structure but not the database
logs/*.db
logs/*.log

# Jupyter checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoints

# Env & secrets
.env
.env.*
*.env

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# pytest
.pytest_cache/
htmlcov/
.coverage